terraform {
  required_version = ">= 1.5"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 6.0"
    }
    random = {
      source  = "hashicorp/random"
      version = ">= 3.0"
    }
    archive = {
      source  = "hashicorp/archive"
      version = ">= 2.0"
    }
  }
}

provider "aws" {
  region = var.region
}

# CLOUDFRONT-scope WAF must live in us-east-1 regardless of var.region.
provider "aws" {
  alias  = "us_east_1"
  region = "us-east-1"
}
