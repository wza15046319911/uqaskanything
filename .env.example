# 复制为 .env 并填入你的 key:  cp .env.example .env
# 规则:设了 DEEPSEEK_API_KEY 就全程走 DeepSeek(planner 路由 + answer 生成);留空/删掉就用本地 Ollama。
# 格式必须是 KEY=VALUE,不能只贴裸 key。

DEEPSEEK_API_KEY=

# 可选项(一般不用改):
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE=https://api.deepseek.com
# LLM_BACKEND=ollama              # 即使设了 key 也强制走本地(临时回退用)
# LLM_MODEL=qwen2.5-coder:7b      # 本地模型
# OLLAMA_URL=http://localhost:11434
