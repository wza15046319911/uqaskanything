# 复制为 eval/.env 并填 DEEPSEEK_API_KEY:  cp eval/.env.example eval/.env
# judge LLM = DeepSeek(必填 key);embedding = 本地 Ollama bge-m3(需本机 ollama 已起)。

DEEPSEEK_API_KEY=
DEEPSEEK_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

OLLAMA_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=bge-m3

# 被评测的后端(generate.py 通过 HTTP 调它拿答案+检索上下文)
BACKEND_URL=http://127.0.0.1:8077
