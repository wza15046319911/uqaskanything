# Copy to eval/.env and fill in DEEPSEEK_API_KEY:  cp eval/.env.example eval/.env
# judge LLM = DeepSeek (key required); embedding = local Ollama bge-m3 (local ollama must already be running).

DEEPSEEK_API_KEY=
DEEPSEEK_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

OLLAMA_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=bge-m3

# The backend under evaluation (generate.py calls it over HTTP to get the answer + retrieval context)
BACKEND_URL=http://127.0.0.1:8077
