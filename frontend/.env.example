# Copy to .env.local and fill in. All frontend env vars must be prefixed with VITE_.

# Cloudflare Turnstile site key (public). Set it to turn on human verification on the
# paid endpoints (/api/ask*, /api/sim/advise). Leave empty to disable (local dev / no key).
# The matching secret goes in the backend env as TURNSTILE_SECRET — never put the secret here.
VITE_TURNSTILE_SITEKEY=
