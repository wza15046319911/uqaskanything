# 复制为 .env 并填入你的 key:  cp .env.example .env
# 规则:设了 DEEPSEEK_API_KEY 就全程走 DeepSeek(planner 路由 + answer 生成);留空/删掉就用本地 Ollama。
# 格式必须是 KEY=VALUE,不能只贴裸 key。

DEEPSEEK_API_KEY=

# 可选项(一般不用改):
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE=https://api.deepseek.com
# LLM_ENABLED=false               # 设 false:即使有 key 也强制走本地 Ollama(默认 true)
# LLM_MODEL=qwen2.5-coder:7b      # 本地模型
# OLLAMA_URL=http://localhost:11434

# --- Bedrock gpt-oss + DeepInfra bge-m3 (for the AgentCore deploy; also for local eval verification) ---
# In production these are injected into the Runtime by Terraform; shown here only for local LLM_BACKEND=bedrock testing.
# Note: retrieval.py does NOT auto-load .env, so EMBED_* must be in the process env (shell export or systemd).
# LLM_BACKEND=bedrock             # force Bedrock (empty = auto by DEEPSEEK_API_KEY)
# BEDROCK_MODEL=openai.gpt-oss-120b-1:0
# BEDROCK_REGION=us-east-1
# EMBED_BASE=https://api.deepinfra.com/v1/openai
# EMBED_MODEL=BAAI/bge-m3
# EMBED_API_KEY=                  # DeepInfra key

# watch_s2 邮件通知(每次监听运行后发汇总邮件)。Gmail 需用「应用专用密码」,不是登录密码。
# 注意:本加载器不剥离行尾注释,值后面别加 # 注释;密码去掉所有空格(Gmail 显示的 16 位带空格要删掉)。
# WATCH_SMTP_USER=zianwang9911@gmail.com
# WATCH_SMTP_PASS=abcdefghijklmnop
# WATCH_MAIL_TO=zianwang9911@gmail.com
# WATCH_SMTP_HOST=smtp.gmail.com
# WATCH_SMTP_PORT=465
