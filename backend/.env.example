# Copy to .env and fill in your key:  cp .env.example .env
# Rule: if DEEPSEEK_API_KEY is set, everything goes through DeepSeek (planner routing + answer generation); leave it blank/remove it to use local Ollama.
# The format must be KEY=VALUE, do not just paste a bare key.

DEEPSEEK_API_KEY=

# --- Protection for cost-heavy endpoints (/api/ask, /api/ask/stream, /api/sim/advise), see app/core/ratelimit.py ---
# LLM_DAILY_CAP=3000              # Global daily cap on paid requests (billing breaker); once exceeded, this group of endpoints returns busy for the rest of the day; set 0 to disable
# RL_PER_MIN=20                   # Per-IP per-minute cap (counted by CF-Connecting-IP behind the CF proxy); set 0 to disable
# TURNSTILE_SECRET=               # Only when set does Cloudflare Turnstile human verification turn on (the frontend must also embed the widget and send the cf-turnstile-response header); leave blank to disable

# Optional (usually no need to change):
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE=https://api.deepseek.com
# LLM_ENABLED=false               # Set false: force local Ollama even if a key exists (default true)
# LLM_MODEL=qwen2.5-coder:7b      # Local model
# OLLAMA_URL=http://localhost:11434

# --- Bedrock gpt-oss + DeepInfra bge-m3 (for the AgentCore deploy; also for local eval verification) ---
# In production these are injected into the Runtime by Terraform; shown here only for local LLM_BACKEND=bedrock testing.
# Note: retrieval.py does NOT auto-load .env, so EMBED_* must be in the process env (shell export or systemd).
# LLM_BACKEND=bedrock             # force Bedrock (empty = auto by DEEPSEEK_API_KEY)
# BEDROCK_MODEL=openai.gpt-oss-120b-1:0
# BEDROCK_REGION=us-east-1
# EMBED_BASE=https://api.deepinfra.com/v1/openai
# EMBED_MODEL=BAAI/bge-m3
# EMBED_API_KEY=                  # DeepInfra key

# watch_s2 email notification (sends a summary email after each watch run). Gmail needs an "app-specific password", not the login password.
# Note: this loader does not strip end-of-line comments, so do not add a # comment after a value; remove all spaces from the password (the 16-digit string Gmail shows with spaces must have them deleted).
# WATCH_SMTP_USER=zianwang9911@gmail.com
# WATCH_SMTP_PASS=abcdefghijklmnop
# WATCH_MAIL_TO=zianwang9911@gmail.com
# WATCH_SMTP_HOST=smtp.gmail.com
# WATCH_SMTP_PORT=465
